{
  "name": "recipe-organizer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "dev": "vp dev",
    "check": "vp check --fix",
    "serve": "vp preview",
    "analyze": "ANALYZE=1 vp build",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "bun run ./scripts/apply-migration-local.ts",
    "db:migrate:remote": "drizzle-kit migrate",
    "db:dump": "rm -f database.sql && wrangler d1 export recipe-organizer --output=./database.sql --no-schema",
    "db:import": "wrangler d1 execute recipe-organizer --file ./database.sql",
    "knip": "knip"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@lexical/list": "0.46.0",
    "@lexical/react": "0.46.0",
    "@lexical/rich-text": "0.46.0",
    "@lexical/utils": "0.46.0",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-form": "1.33.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/react-store": "0.11.0",
    "@valibot/i18n": "^1.0.0",
    "better-auth": "^1.6.22",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "1.0.0-beta.22",
    "lexical": "0.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.3",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@serwist/build": "9.5.11",
    "@serwist/vite": "9.5.11",
    "@serwist/window": "9.5.11",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-router-devtools": "1.167.0",
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/devtools": "0.3.3",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "1.0.0-beta.22",
    "knip": "6.23.0",
    "lefthook": "2.1.9",
    "rollup-plugin-visualizer": "^7.0.1",
    "serwist": "9.5.11",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite-plus": "0.2.1",
    "wrangler": "4.105.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
