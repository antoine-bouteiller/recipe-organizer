{
  "name": "recipe-organizer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "dev": "CLOUDFLARE_ENV=dev vp dev",
    "check": "vp check --fix",
    "serve": "vp preview",
    "cf-typegen": "wrangler types",
    "migration:apply:local": "bun run ./scripts/apply-migration-local.ts",
    "migration:apply:remote": "drizzle-kit migrate",
    "db:dump": "rm -f database.sql && wrangler d1 export recipe-organizer --output=./database.sql --no-schema",
    "db:import": "wrangler d1 execute recipe-organizer --file ./database.sql",
    "knip": "knip",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@lexical/list": "0.44.0",
    "@lexical/react": "0.44.0",
    "@lexical/rich-text": "0.44.0",
    "@lexical/utils": "0.44.0",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-form": "1.32.1",
    "@tanstack/react-query": "5.100.14",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-ssr-query": "1.167.0",
    "@tanstack/react-start": "1.168.14",
    "@vidstack/react": "1.13.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "1.0.0-beta.22",
    "lexical": "0.44.0",
    "motion": "12.40.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.39.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@serwist/build": "9.5.11",
    "@serwist/vite": "9.5.11",
    "@serwist/window": "9.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query-devtools": "5.100.14",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tsconfig/vite-react": "7.0.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "1.0.0-beta.22",
    "knip": "6.14.2",
    "serwist": "9.5.11",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite-plus": "0.1.20",
    "wrangler": "4.95.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "pnpm@11.3.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest"
    }
  }
}
