{
  "name": "recipe-organizer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vp build",
    "dev": "CLOUDFLARE_ENV=dev vp dev",
    "check": "vp check --fix",
    "serve": "vp preview",
    "cf-typegen": "wrangler types",
    "migration:apply:local": "bun run ./scripts/apply-migration-local.ts",
    "migration:apply:remote": "drizzle-kit migrate",
    "db:dump": "rm -f database.sql && wrangler d1 export recipe-organizer --output=./database.sql --no-schema",
    "db:import": "wrangler d1 execute recipe-organizer --file ./database.sql",
    "knip": "knip",
    "prepare": "vp config"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@lexical/list": "0.43.0",
    "@lexical/react": "0.43.0",
    "@lexical/rich-text": "0.43.0",
    "@lexical/utils": "0.43.0",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-form": "1.29.0",
    "@tanstack/react-query": "5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.167.42",
    "@vidstack/react": "1.12.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "1.0.0-beta.22",
    "lexical": "0.43.0",
    "motion": "12.38.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.33.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@serwist/build": "9.5.7",
    "@serwist/vite": "9.5.7",
    "@serwist/window": "9.5.7",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.3",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-query-devtools": "5.99.2",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tsconfig/vite-react": "7.0.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "1.0.0-beta.22",
    "knip": "6.5.0",
    "serwist": "9.5.7",
    "tailwindcss": "4.2.3",
    "typescript": "6.0.3",
    "vite-plus": "0.1.19",
    "wrangler": "4.84.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest"
    }
  }
}
