{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./.void/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "void/db": ["./.void/db.d.ts"],
      "@schema": ["./db/schema.ts"],
      "@schema/*": ["./db/schema/*"]
    },
    "lib": ["ESNext", "DOM", "DOM.Iterable", "webworker"],
    "types": ["vite-plus/client", "@serwist/vite/typings", "void/env"]
  },
  "include": ["src", "db", "scripts"]
}
